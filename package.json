{
  "name": "noto-crm-mcp-server",
  "version": "1.1.0",
  "mcpName": "io.github.migmediamarketing-ai/noto-crm",
  "repository": {
    "type": "git",
    "url": "https://github.com/migmediamarketing-ai/Noto-CRM-MCP-Server.git"
  },
  "description": "MCP server for Noto CRM — minimalist CRM with AI agent for French freelancers and solopreneurs. CRM freelance, CRM solopreneur, CRM minimaliste français, CRM avec IA.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "noto-crm-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "crm",
    "crm-freelance",
    "crm-ia",
    "freelance",
    "solopreneur",
    "freelance-productivity",
    "client-management",
    "prospection-freelance",
    "solopreneur-tools",
    "ai-agent",
    "ai-crm",
    "noto",
    "gestion-client-independant",
    "lead-tracking",
    "sales-pipeline",
    "task-management-freelance"
  ],
  "author": "Noto",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
